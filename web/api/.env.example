# Backend (Render) — copie para .env em dev, ou configure no painel do Render.
APP_PASSWORD=troque-esta-senha
JWT_SECRET=gere-um-segredo-longo-aleatorio
# Connection string do Supabase (Project Settings > Database > Connection string > URI).
# Use o pooler (porta 6543, transaction mode) pra Render.
DATABASE_URL=postgresql://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
CORS_ORIGIN=https://seu-app.vercel.app
# PORT é definido pelo Render automaticamente
